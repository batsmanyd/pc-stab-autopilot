<Window
    x:Class="FluentCleaner.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="PC Штаб Автопилот">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar x:Name="AppTitleBar"
                  Grid.Row="0"
                  Title="PC Штаб Автопилот"
                  Subtitle=""
                  IsPaneToggleButtonVisible="True"
                  PaneToggleRequested="TitleBar_PaneToggleRequested">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="Assets/AppIcon.ico" />
            </TitleBar.IconSource>

            <TitleBar.Content>
                <Grid>
                    <AutoSuggestBox x:Name="TitleSearchBox"
                        MinWidth="160"
                        MaxWidth="280"
                        Width="280"
                        VerticalAlignment="Center"
                        PlaceholderText="Поиск"
                        QueryIcon="Find"
                        TextChanged="TitleSearchBox_TextChanged" />

                    <Button x:Name="SearchIconButton"
                        Width="32"
                        Height="32"
                        Padding="0"
                        Visibility="Collapsed"
                        Background="Transparent"
                        BorderThickness="0"
                        ToolTipService.ToolTip="Поиск">
                        <FontIcon Glyph="&#xE721;" FontSize="15" />
                        <Button.Flyout>
                            <Flyout Placement="Bottom">
                                <AutoSuggestBox Width="280"
                                    PlaceholderText="Поиск"
                                    QueryIcon="Find"
                                    TextChanged="TitleSearchBox_TextChanged" />
                            </Flyout>
                        </Button.Flyout>
                    </Button>
                </Grid>
            </TitleBar.Content>

            <TitleBar.RightHeader>
                <Button x:Name="BtnPageActions" Width="32" Height="32" Padding="0" Visibility="Collapsed">
                    <FontIcon Glyph="&#xE712;" FontSize="14" />
                    <Button.Flyout>
                        <MenuFlyout x:Name="PageActionsFlyout" Opening="PageActionsFlyout_Opening" />
                    </Button.Flyout>
                </Button>
            </TitleBar.RightHeader>
        </TitleBar>

        <NavigationView x:Name="NavView"
                        Grid.Row="1"
                        PaneDisplayMode="LeftCompact"
                        IsTitleBarAutoPaddingEnabled="False"
                        IsBackButtonVisible="Collapsed"
                        IsPaneToggleButtonVisible="False"
                        CompactPaneLength="48"
                        OpenPaneLength="240"
                        SelectionChanged="NavView_SelectionChangedWithAutopilot">

            <NavigationView.MenuItems>
                <NavigationViewItem Tag="Autopilot" Content="Автопилот" IsSelected="True">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE7C1;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Tag="Cleaner" Content="Очистка вручную">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xEA99;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <Frame x:Name="NavFrame" />
        </NavigationView>

        <TeachingTip x:Name="DonationTip" Target="{x:Bind BtnPageActions}" IsOpen="False" Title="" Subtitle="" />
    </Grid>
</Window>

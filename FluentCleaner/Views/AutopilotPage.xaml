<Page
    x:Class="FluentCleaner.Views.AutopilotPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel Padding="32" Spacing="18" MaxWidth="920" HorizontalAlignment="Left">
            <TextBlock Text="PC Stab Autopilot"
                       FontSize="32"
                       FontWeight="SemiBold" />

            <TextBlock Text="Automatic PC check, scheduled reports, and simple status for normal users."
                       TextWrapping="Wrap"
                       Opacity="0.8" />

            <InfoBar IsOpen="True"
                     Severity="Informational"
                     Title="MVP mode"
                     Message="This first autopilot screen checks the PC and creates reports. System changes are not performed in this mode." />

            <Grid ColumnSpacing="16" RowSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Grid.Column="0" Padding="18" CornerRadius="14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Status" FontWeight="SemiBold" />
                        <TextBlock x:Name="StatusText" Text="Waiting" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="0" Grid.Column="1" Padding="18" CornerRadius="14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Last check" FontWeight="SemiBold" />
                        <TextBlock x:Name="LastRunText" Text="Not run yet" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Grid.Column="0" Padding="18" CornerRadius="14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Temporary files" FontWeight="SemiBold" />
                        <TextBlock x:Name="TempText" Text="—" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Grid.Column="1" Padding="18" CornerRadius="14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Warnings" FontWeight="SemiBold" />
                        <TextBlock x:Name="WarningsText" Text="—" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>

            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button x:Name="RunNowButton" Content="Run check now" Click="RunNow_Click" />
                <Button x:Name="EnableButton" Content="Enable daily autopilot" Click="Enable_Click" />
                <Button x:Name="DisableButton" Content="Disable autopilot" Click="Disable_Click" />
                <Button Content="Open reports" Click="OpenReports_Click" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
